# MongoDB
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.example.mongodb.net/CRM-DEV?appName=Cluster0
PROD_DB=mongodb+srv://<user>:<pass>@cluster0.example.mongodb.net/CRM?appName=Cluster0

# OpenAI (used for AI prompt generation)
OPENAI=sk-proj-...

# Redis (Upstash)
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# Instagram / Meta App
IG_APP_ID=
IG_APP_SECRET=
FB_APP_SECRET=
IG_VERIFY_TOKEN=
IG_REDIRECT_URI=https://your-app.vercel.app/settings/integrations

# Encryption key for API tokens at rest (AES-256-GCM, 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# JWT secret (required in production)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Server port (default: 3000)
PORT=3000
